{
  "name": "league-akari",
  "version": "1.5.0-rabi.1",
  "author": {
    "name": "hanxven",
    "email": "hanxven@gmail.com"
  },
  "description": "League Akari",
  "main": "./out/main/main.js",
  "scripts": {
    "format": "prettier --write .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "electron-vite preview",
    "dev": "electron-vite dev --watch -- --inspect",
    "dev:no-watch": "electron-vite dev -- --inspect",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "build": "npm run typecheck && electron-vite build",
    "benchmark:radix": "vitest bench src/shared/utils/radix-matcher.bench.ts",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win --config",
    "gen-types": "tsc --declaration --emitDeclarationOnly --outDir ./out/types -p tsconfig.node.json",
    "build:mac": "npm run build && electron-builder --mac --arm64 --dir --config && node scripts/macos/ensure-codesign.cjs \"dist/mac-arm64/League Akari.app\" && electron-builder --mac --arm64 --config --prepackaged \"dist/mac-arm64/League Akari.app\""
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@leagueakari/league-akari-addons": "^1.0.0",
    "axios-retry": "^4.5.0",
    "better-sqlite3": "^12.10.0",
    "luaparse": "^0.3.1",
    "mime-types": "^3.0.2",
    "mobx": "^6.15.3",
    "reflect-metadata": "^0.2.2",
    "regedit": "^5.1.4",
    "typeorm": "^1.0.0",
    "winston": "^3.19.0",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/notarize": "^3.1.1",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@storybook/vue3-vite": "^10.4.0",
    "@swc/core": "^1.15.33",
    "@tailwindcss/vite": "^4.3.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/lodash": "^4.17.24",
    "@types/luaparse": "^0.2.13",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.1",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "@uiw/codemirror-theme-vscode": "^4.25.9",
    "@vicons/antd": "^0.13.0",
    "@vicons/carbon": "^0.13.0",
    "@vicons/fa": "^0.13.0",
    "@vicons/fluent": "^0.13.0",
    "@vicons/ionicons5": "^0.13.0",
    "@vicons/material": "^0.13.0",
    "@vicons/tabler": "^0.13.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/compiler-dom": "^3.5.34",
    "@vue/test-utils": "^2.4.10",
    "@vueuse/components": "^14.3.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/router": "^14.3.0",
    "axios": "^1.16.1",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "codemirror": "^6.0.2",
    "dayjs": "^1.11.20",
    "electron": "^41.7.0",
    "electron-builder": "26.8.1",
    "electron-vite": "^5.0.0",
    "gray-matter": "^4.0.3",
    "i18next": "^26.2.0",
    "i18next-vue": "^5.4.0",
    "lodash": "^4.18.1",
    "markdown-it": "^14.1.1",
    "mitt": "^3.0.1",
    "naive-ui": "^2.44.1",
    "p-queue": "^9.3.0",
    "pinia": "^3.0.4",
    "pinyin-pro": "^3.28.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "quick-lru": "^7.3.0",
    "safe-stable-stringify": "^2.5.0",
    "semver": "^7.8.0",
    "storybook": "^10.4.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vfonts": "^0.0.3",
    "vite": "^7.3.3",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.7",
    "vue": "^3.5.34",
    "vue-chartjs": "^5.3.3",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^5.0.7",
    "vue-tsc": "^3.3.1"
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
