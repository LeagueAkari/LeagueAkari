    "luaparse": "^0.3.1",
    "mime-types": "^3.0.2",
    "mobx": "^6.15.0",
    "reflect-metadata": "^0.2.2",
    "regedit": "^5.1.4",
    "sqlite3": "5.1.7",
    "typeorm": "^0.3.28",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
