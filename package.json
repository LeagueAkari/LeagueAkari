    "@electron/notarize": "^3.1.1",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@swc/core": "1.15.11",
    "@tailwindcss/vite": "^4.1.18",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/lodash": "^4.17.23",
    "@types/luaparse": "^0.2.13",
    "@types/markdown-it": "^14.1.2",
